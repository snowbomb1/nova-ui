{
  "name": "@snowbomb1/nova-ui",
  "version": "1.1.1",
  "type": "module",
  "private": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/snowbomb1/nova-ui"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/nova-ui.css"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && vite build && cp src/styles.d.ts dist/styles.d.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint"
  },
  "peerDependencies": {
    "motion": "^12.33.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "globals": "^17.3.0",
    "motion": "^12.33.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.18"
  }
}